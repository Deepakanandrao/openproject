<%=
  render(Primer::Beta::BorderBox.new) do |component|
    component.with_header do |header|
      header.with_title(tag: :h2) do
        Type.model_name.human
      end
    end
    types.each do |type|
      component.with_row(data: { "filter--filter-list-target": "searchItem" }) do
        flex_layout(align_items: :center, justify_content: :space_between) do |type_row|
          type_row.with_column do
            tag.span type.name, class: "text-bold"
          end
          type_row.with_column do
            render(Primer::Beta::ButtonGroup.new) do |component|
              component.with_button(
                tag: :a,
                mobile_icon: :pencil,
                mobile_label: t(:button_edit),
                href: edit_workflow_path(type),
                aria: { label: I18n.t(:button_edit) },
                title: I18n.t(:button_edit)
              ) do |button|
                button.with_leading_visual_icon(icon: :pencil)
                t(:button_edit)
              end
              component.with_menu_button(button_arguments: { "aria-label": t("label_more") }, menu_arguments: { anchor_align: :end }) do |menu, button|
                menu.with_item(label: t("label_copy_workflow_from_type"), href: new_workflow_copy_from_type_path(type), icon: :copy)
                menu.with_item(label: t("label_copy_workflow_from_role"), href: new_workflow_copy_from_role_path(type))
              end
            end
          end
        end
      end
    end
    if types.empty?
      component.with_row do
        render(Primer::Beta::Blankslate.new(border: false)) do |component|
          component.with_heading(tag: :h2) { I18n.t(:label_nothing_display) }
          component.with_description { I18n.t(:no_results_title_text) }
        end
      end
    end
  end
%>
