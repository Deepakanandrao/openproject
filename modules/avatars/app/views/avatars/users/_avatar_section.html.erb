<% manager = ::OpenProject::Avatars::AvatarManager %>
<% if User.current.admin? && manager.avatars_enabled? %>
  <%= render(Primer::Beta::Subhead.new(mb: 2)) do |subhead| %>
    <% subhead.with_heading(tag: :h3, size: :medium) { t("avatars.label_avatar") } %>
  <% end %>

  <%= render "avatars/users/avatar_fields", user:, target_avatar_path: edit_user_avatar_path(user) %>
<% end %>
