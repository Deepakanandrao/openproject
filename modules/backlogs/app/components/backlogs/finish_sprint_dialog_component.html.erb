<%=
  render(
    Primer::Alpha::Dialog.new(
      title:,
      id: DIALOG_ID
    )
  ) do |d|
    d.with_header(variant: :large)

    d.with_body do
      concat(tag.p(body_message))

      concat(
        form_with(
          url: finish_project_sprint_path(project, sprint),
          method: :post,
          id: FORM_ID
        ) do
          render(Primer::Alpha::Select.new(name: :move_to_sprint_id, label: t(".select_sprint_label"))) do |select|
            available_sprints.each do |s|
              select.option(label: s.name, value: s.id)
            end
          end
        end
      )
    end

    d.with_footer do
      component_collection do |buttons|
        buttons.with_component(
          Primer::Beta::Button.new(data: { close_dialog_id: DIALOG_ID })
        ) do
          t("button_cancel")
        end

        buttons.with_component(
          Primer::Beta::Button.new(
            scheme: :primary,
            form: FORM_ID,
            type: :submit
          )
        ) do
          t(".button_close_sprint")
        end
      end
    end
  end
%>
