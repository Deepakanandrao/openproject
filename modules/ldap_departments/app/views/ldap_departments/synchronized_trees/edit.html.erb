<% html_title(t(:label_administration), t(:label_edit_x, x: @tree.name)) -%>

<%=
  render Primer::OpenProject::PageHeader.new do |header|
    header.with_title { @tree.name }
    header.with_breadcrumbs(
      [
        { href: admin_index_path, text: t(:label_administration) },
        { href: admin_settings_authentication_path, text: t(:label_authentication) },
        { href: ldap_departments_synchronized_trees_path, text: I18n.t("ldap_departments.label_menu_item") },
        nested_breadcrumb_element(t("ldap_departments.synchronized_trees.singular"), @tree.name)
      ],
      selected_item_font_weight: :normal
    )
  end
%>

<%= labelled_tabular_form_for @tree,
                              as: :synchronized_tree,
                              url: { action: :update } do |f| %>

  <%= render partial: "form", locals: { f: } %>

  <p>
    <%= styled_button_tag t(:button_save), class: "-primary -with-icon icon-checkmark" %>
    <%= link_to t(:button_cancel), { action: :show }, class: "button -with-icon icon-cancel" %>
  </p>
<% end %>
