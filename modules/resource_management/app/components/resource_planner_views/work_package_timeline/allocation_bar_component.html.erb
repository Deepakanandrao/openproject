<div class="op-rm-timeline-bar">
  <span class="op-rm-timeline-bar--hours"><%= hours_label %></span>

  <% if principal_visible? %>
    <% if avatar_image_url.present? %>
      <%= render(Primer::Beta::Avatar.new(src: avatar_image_url, alt: principal_name, size: 16)) %>
    <% else %>
      <span class="op-rm-timeline-bar--initials" aria-hidden="true"><%= initials %></span>
    <% end %>
    <span class="op-rm-timeline-bar--label"><%= principal_name %></span>
  <% else %>
    <%= render(Primer::Beta::Octicon.new(icon: :"person-add", size: :small)) %>
    <span class="op-rm-timeline-bar--label"><%= placeholder_label %></span>
  <% end %>

  <% if candidate_badge? %>
    <span class="op-rm-timeline-bar--badge">
      <%= render(Primer::Beta::Label.new(scheme: :secondary)) { candidate_label } %>
    </span>
  <% end %>
</div>
