<%=
  render(
    Primer::Alpha::Dialog.new(
      id:,
      title: t(".title"),
      size: :large,
      data: {
        controller: "wikis--add-existing-page",
        "wikis--add-existing-page-provider-id-value": provider.id
      },
      **system_arguments
    )
  ) do |dialog|
%>
  <% dialog.with_body do %>
    <% primer_form_with(**form_options) do |form| %>
      <%= render(Primer::Alpha::Stack.new) do %>
        <%= render(Wikis::LinkExistingWikiPageForm.new(form)) %>

        <%=
          render(
            Primer::Alpha::TextField.new(
              name: "search",
              label: "Search",
              visually_hide_label: true,
              id: "search-wiki-page-input",
              placeholder: "Enter search term or wiki page URL",
              leading_visual: { icon: :search, size: :small },
              data: {
                wikis__add_existing_page_target: "searchInput",
                action: "input->wikis--add-existing-page#search"
              }
            )
          )
        %>

        <%=
          helpers.turbo_frame_tag SEARCH_RESULTS_FRAME_ID,
                                  refresh: :morph,
                                  data: { wikis__add_existing_page_target: "searchResultsFrame" } do
            render(Wikis::PageSearchResults.new(Dry::Monads::Success([])))
          end
        %>

      <% end %>
    <% end %>
  <% end %>

  <% dialog.with_footer do %>
    <%= render(Primer::Beta::Button.new(data: { "close-dialog-id": id })) { t("button_cancel") } %>
    <%= render(Primer::Beta::Button.new(scheme: :primary, form: form_id, type: :submit)) { t("button_add") } %>
  <% end %>
<% end %>
